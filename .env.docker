# Docker Configuration for Tunisian Economic Intelligence System

# Oracle Database Configuration
DB_URL=jdbc:oracle:thin:@//host.docker.internal:1521/FREE
DB_USER=SYSTEM
DB_PASSWORD=system

# Java Settings
JAVA_OPTS=-Xms256m -Xmx512m

# Python Environment
PYTHONUNBUFFERED=1

# API Configuration
JAVA_API_BASE=http://java-api:8080/api

# Ports (can be overridden in docker-compose.yml)
JAVA_PORT=8080
CHAT_PORT=8010
ML_PORT=8000
